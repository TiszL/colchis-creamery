}

// ─── ReviewPhoto ─────────────────────────────────────────────────────────────

model ReviewPhoto {
  id        String   @id @default(uuid())
  reviewId  String
  imageUrl  String
  createdAt DateTime @default(now())

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// ─── ReviewReply ─────────────────────────────────────────────────────────────
// Follow-up replies on reviews (by customer or admin)

model ReviewReply {
  id           String   @id @default(uuid())
  reviewId     String
  userId       String
  body         String
  isAdminReply Boolean  @default(false)
  createdAt    DateTime @default(now())

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Site Settings ──────────────────────────────────────────────────────────
// Key-value store for admin-configurable settings

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

// ─── ChatSession ────────────────────────────────────────────────────────────
// Live support chat sessions between visitors and staff
// status: "WAITING" | "ACTIVE" | "CLOSED"

model ChatSession {
  id            String    @id @default(uuid())
  visitorId     String                          // localStorage UUID for anonymous users
  visitorName   String?
  visitorEmail  String?
  userId        String?                         // FK → User (if visitor is logged in)
  assignedToId  String?                         // FK → User (staff who claimed session)
  status        String    @default("WAITING")   // WAITING | ACTIVE | CLOSED
  lastMessageAt DateTime  @default(now())
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User?         @relation("ChatVisitor", fields: [userId], references: [id])
  assignedTo User?         @relation("ChatAgent", fields: [assignedToId], references: [id])
  messages   ChatMessage[]

  @@index([status])
  @@index([assignedToId])
  @@index([visitorId])
}

// ─── ChatMessage ────────────────────────────────────────────────────────────
// Individual messages within a chat session
// sender: "visitor" | "agent" | "system"

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  sender    String                              // "visitor" | "agent" | "system"
  agentId   String?                             // FK → User (if sent by staff)
  body      String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ─── Multi-Location Fulfillment ──────────────────────────────────────────────
// A Location is a physical place that holds Stock for Products and offers one
// or more delivery Channels with their own radius / fee rules. Each Product can
// opt into specific Channels (ProductChannel); a Customer at lat/lng sees only
// products whose (Stock at L, Channel at L) reaches them.

enum LocationType {
  BAKERY              // hot bakery — local delivery + 3rd-party platforms + walk-in
  D2C_COLD_WAREHOUSE  // owned cold storage, UPS 2-day shipping
  B2B_3PL_WAREHOUSE   // third-party logistics for B2B cold chain (future)
}

// DeliveryMethod describes HOW an order moves (carrier, channel pricing,
// driver type). Orthogonal to SalesChannel (which describes WHAT business
// line the SKU belongs to). @@map keeps the underlying Postgres enum name
// as the legacy "DeliveryMethod" so this is a zero-data-migration rename.
enum DeliveryMethod {
  UPS_2DAY               @map("UPS_GROUND_2DAY")    // nationwide cold-chain via UPS 2nd Day Air (or FedEx 2Day fallback)
  OWN_DELIVERY           @map("HOT_DELIVERY_OWN")   // location's own drivers, short radius — used for hot food + local cheese
  DOORDASH_DRIVE         // DoorDash Drive API (our platform, lower fee)
  UBER_DIRECT            // Uber Direct API (our platform, lower fee)
  DOORDASH_MARKETPLACE   // listed on DoorDash app (higher fee, future)
  UBER_EATS_MARKETPLACE  // listed on Uber Eats app (higher fee, future)
  IN_STORE_PICKUP        // customer picks up at the bakery
  IN_STORE_DINE_IN       // customer eats at the bakery (e.g. hot khachapuri)
  MANUAL_DISPATCH        // B2B 3PL/freight booked manually by ops (Phase 6)

  @@map("DeliveryMethod")
}

model Location {
  id            String       @id @default(uuid())
  name          String                                // "Bakery — Dublin OH" / "Cold Warehouse — Columbus"
  type          LocationType
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  postalCode    String
  country       String       @default("US")
  latitude      Float?                                // populated via Google Places at admin save
  longitude     Float?
  googlePlaceId String?                               // store Place ID for re-lookup
  phone         String?
  hours         Json?                                 // { mon: "07:00-21:00", tue: "07:00-21:00", ... }
  isActive      Boolean      @default(true)
  notes         String?

  // Phase 10: display-layer fields. The Location table is the single source of
  // truth for both operational routing AND the brand-address shown across the
  // site (footer, homepage Visit, contact page, JSON-LD). Exactly one row is
  // isPrimary=true at a time; that row drives every "where do we read the brand
  // address" call via getPrimaryLocation().
  isPrimary             Boolean @default(false)
  showOnContactPage     Boolean @default(true)
  displayDescription    String?  // homepage Visit copy + contact card body
  displayBakeryHours    String?  // "Wed–Sun · 8a–9p" style short form
  contactCardName       String?  // vanity name shown on /contact, e.g. "The High St Counter"
  contactCardDoorNote   String?  // e.g. "Door 4 · ring twice"
  displayOrder          Int      @default(0)  // sort order for multi-location display on /contact

  // Phase 1: catalog channel allowlist. Which SalesChannels this location
  // handles. A bakery typically allows [LOCAL_HOT, LOCAL_COLD]; the cold
  // warehouse allows [NATIONAL_SHIP]; a B2B 3PL allows [B2B_WHOLESALE,
  // B2B_FROZEN]. Empty array by default; populated by 1c backfill from
  // LocationType, then admin-editable.
  allowsChannels        SalesChannel[]  @default([])

  // Phase 4 — Stripe Connect routing. When stripeConnectAccountId is set
  // AND stripeOnboardingStatus is 'complete', checkout creates the
  // PaymentIntent with transfer_data.destination so the charge settles to
  // this location's connected account (sub-LLC bank). When null, payments
  // stay on the platform account (current pre-Connect behavior).
  //
  // Status mirrors Stripe's account.requirements signal:
  //   null         — never started onboarding
  //   'pending'    — onboarding link issued, details_submitted=false
  //   'restricted' — onboarded but requirements outstanding (charges may be off)
  //   'complete'   — charges_enabled && payouts_enabled
  stripeConnectAccountId    String?  @unique
  stripeOnboardingStatus    String?
  stripeOnboardingUpdatedAt DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  channels     LocationDeliveryMethod[]
  stocks       Stock[]
  fulfillments OrderFulfillment[]
  userRoles    UserLocation[]
  batches      ProductBatch[]
  stockMovements StockMovement[]
  // Phase 6 — B2B partner default warehouse + recurring schedule pinning.
  b2bPartnerDefaults       B2bPartner[]             @relation("B2bPartnerDefaultLocation")
  recurringSchedules       RecurringOrderSchedule[] @relation("RecurringScheduleLocation")
}

// Renamed from LocationChannel for clarity (the relation is one delivery
// method per location, with its own fee/radius config). @@map keeps the
// underlying Postgres table name as the legacy "LocationChannel" so the
// rename costs no data migration. Field `deliveryMethod` is @map'd to the
// legacy "channel" column for the same reason.
model LocationDeliveryMethod {
  id              String         @id @default(uuid())
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  deliveryMethod  DeliveryMethod @map("channel")
  radiusMiles     Float?                            // 25 for OWN_DELIVERY, ~1200 for UPS (20h drive); null = no radius gate
  maxDriveHours   Float?                            // alt to radiusMiles, used for UPS cold-chain
  flatFee         String?                           // dollars, stringly-typed to match Product.priceB2c convention
  perMileFee      String?                           // dollars per mile
  priceMultiplier Float          @default(1.0)      // 1.0 own platform, 1.3 marketplace markup
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([locationId, deliveryMethod], map: "LocationChannel_locationId_channel_key")
  @@map("LocationChannel")
}

model Stock {
  id                String   @id @default(uuid())
  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Int?                              // NULL = made-to-order (unlimited while location open)
  reservedQuantity  Int      @default(0)
  lowStockThreshold Int      @default(0)
  // Phase 9c: per-location menu toggle. When false, the SKU stays in the
  // Stock table (count preserved) but disappears from public availability
  // queries + cart eligibility. Location managers flip this via
  // /location-portal/[id]/menu without losing on-hand counts.
  isEnabled         Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([locationId, productId])
  @@index([productId])
}

// One Order may split across multiple OrderFulfillment rows (one per location).
// Created at checkout time when checkout is implemented (Phase 7).

model OrderFulfillment {
  id                String             @id @default(uuid())
  orderId           String
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  locationId        String
  location          Location           @relation(fields: [locationId], references: [id])
  deliveryMethod    DeliveryMethod     @map("channel")
  status            String             @default("PENDING") // PENDING|CONFIRMED|PREPARING|OUT_FOR_DELIVERY|DELIVERED|CANCELLED
  trackingNumber    String?
  externalOrderId   String?                              // DoorDash/Uber Direct order id
  estimatedDelivery DateTime?
  shippingCost      String?
  // Phase 7a — scheduled fulfillment time (MTO hot food outside hours, or
  // customer-chosen later slot). Null means "as soon as possible".
  scheduledFor      DateTime?
  // Phase 7a — packaging requirement, e.g. "INSULATED_COLD_CHAIN" for UPS creamery.
  // Helps the kitchen/warehouse pick the right packaging.
  packagingType     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  items OrderFulfillmentItem[]

  @@index([orderId])
}

model OrderFulfillmentItem {
  id            String           @id @default(uuid())
  fulfillmentId String
  fulfillment   OrderFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItemId   String
  orderItem     OrderItem        @relation(fields: [orderItemId], references: [id])
  quantity      Int

  @@index([fulfillmentId])
}

// Phase 7b.6 — Refund audit trail.
//
// One row per refund issued against an Order. Captures the Stripe refund id
// for cross-reference, the initiator (admin user or null for system/customer-
// cancel paths), the amount in cents, and a free-text reason + notes.
//
// Multiple refunds can exist per Order (partial refunds accumulate). Sum of
// amountCents must not exceed Order.totalAmount * 100. Enforcement is in the
// refundOrder server action, not at the DB level.
model Refund {
  id                String   @id @default(uuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  initiatedByUserId String?  // null = system (customer-cancel or webhook)
  initiatedBy       User?    @relation(fields: [initiatedByUserId], references: [id])
  amountCents       Int      // refund amount in cents
  reason            String   // 'customer_cancellation' | 'admin_full' | 'admin_partial' | 'admin_other'
  notes             String?  // optional free-text admin note
  stripeRefundId    String?  @unique
  restoredStock     Boolean  @default(false) // did we run restoreStock?
  reversedTax       Boolean  @default(false) // did we issue a tax reversal?
  createdAt         DateTime @default(now())

  @@index([orderId])
  @@index([initiatedByUserId])
}

