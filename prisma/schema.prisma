// Colchis Creamery - Prisma Schema
// Georgian artisanal cheese e-commerce platform
// ─── Multi-Role RBAC Architecture ────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// Roles: MASTER_ADMIN | PRODUCT_MANAGER | CONTENT_MANAGER | SALES
//        B2B_PARTNER | B2C_CUSTOMER | ANALYTICS_VIEWER

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String?
  name              String?
  phone             String?
  avatarUrl         String?
  role              String     @default("B2C_CUSTOMER")
  companyName       String?
  stripeCustomerId  String?
  isActiveB2b       Boolean    @default(false)
  isActive          Boolean    @default(true)
  emailVerified     Boolean    @default(false)
  verificationCode  String?
  verificationExpiry DateTime?
  twoFactorCode     String?
  twoFactorExpiry   DateTime?
  totpSecret        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  orders           Order[]
  contracts        Contract[]
  profile          UserProfile?
  dashboardAccess  DashboardAccess[]
  analyticsPins    AnalyticsPin[]
  accounts         Account[]
  reviews          ProductReview[]
  reviewReplies    ReviewReply[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── UserProfile ─────────────────────────────────────────────────────────────
// Extended profile for B2C customers (shipping, billing)

model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  shippingAddress   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?  @default("US")
  billingAddress    String?
  billingCity       String?
  billingState      String?
  billingZip        String?
  billingCountry    String?  @default("US")
  preferredLanguage String?  @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Product ─────────────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

model Product {
  id             String        @id @default(uuid())
  sku            String        @unique
  name           String
  slug           String        @unique
  description    String
  flavorProfile  String?
  pairsWith      String?
  weight         String?
  ingredients    String?
  imageUrl       String
  images         String[]      @default([])
  videoUrls      String[]      @default([])
  priceB2c       String
  priceB2b       String
  stockQuantity  Int
  category       String?       @default("cheese")
  status         ProductStatus @default(ACTIVE)
  isActive       Boolean       @default(true)
  isB2cVisible   Boolean       @default(true)
  isB2bVisible   Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  orderItems OrderItem[]
  reviews    ProductReview[]
}

// ─── Contract ────────────────────────────────────────────────────────────────
// status: "PENDING" | "OUT_FOR_SIGNATURE" | "SIGNED" | "EXPIRED"

model Contract {
  id                     String    @id @default(uuid())
  partnerId              String
  adobeSignAgreementId   String?
  status                 String    @default("PENDING")
  signedDocumentUrl      String?
  discountPercentage     String    @default("0")
  validUntil             DateTime?
  createdAt              DateTime  @default(now())

  partner User @relation(fields: [partnerId], references: [id])
}

// ─── Order ───────────────────────────────────────────────────────────────────
// orderType: "B2C" | "B2B"
// paymentStatus: "UNPAID" | "PAID" | "REFUNDED"
// orderStatus: "PROCESSING" | "READY_FOR_PICKUP" | "SHIPPED" | "IN_TRANSIT" | "DELIVERED"

model Order {
  id                     String      @id @default(uuid())
  userId                 String
  orderType              String      @default("B2C")
  totalAmount            String
  stripePaymentIntentId  String?
  stripeInvoiceId        String?
  paymentStatus          String      @default("UNPAID")
  orderStatus            String      @default("PROCESSING")
  shippingAddress        String?
  notes                  String?
  createdAt              DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]
  shipment   Shipment?
}

// ─── OrderItem ───────────────────────────────────────────────────────────────

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice String

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

// ─── Shipment ────────────────────────────────────────────────────────────────

model Shipment {
  id                    String    @id @default(uuid())
  orderId               String    @unique
  carrierName           String?
  trackingNumber        String?
  dispatchDate          DateTime?
  estimatedDeliveryDate DateTime?
  deliveryAddress       String?
  createdAt             DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// ─── B2bLead ─────────────────────────────────────────────────────────────────
// status: "NEW" | "CONTACTED" | "CONVERTED" | "REJECTED"

model B2bLead {
  id             String   @id @default(uuid())
  companyName    String
  contactName    String?
  email          String
  phone          String?
  address        String?
  expectedVolume String?
  message        String?
  status         String   @default("NEW")
  assignedTo     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Recipe ──────────────────────────────────────────────────────────────────

model Recipe {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  content       String
  contentBlocks String?  // JSON array of content blocks
  prepTime      String?
  cookTime      String?
  servings      String?
  difficulty    String?
  imageUrl      String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Article ─────────────────────────────────────────────────────────────────
// CMS-managed blog/news articles

model Article {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String
  contentBlocks String?  // JSON array of content blocks
  coverImage    String?
  authorId      String?
  tags          String?
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── AccessCode ──────────────────────────────────────────────────────────────
// type: "B2B" | "STAFF" | "ANALYTICS_VIEWER"
// targetRole: The role assigned when the code is redeemed

model AccessCode {
  id         String    @id @default(uuid())
  code       String    @unique
  type       String    @default("B2B")
  targetRole String    @default("B2B_PARTNER")
  email      String?
  isUsed     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
}

// ─── AnalyticsPin ────────────────────────────────────────────────────────────
// Google Maps markers for business development

model AnalyticsPin {
  id          String   @id @default(uuid())
  name        String
  latitude    Float
  longitude   Float
  pinType     String   @default("PROSPECT")  // PROSPECT | PARTNER | SUPPLIER | ZONE
  status      String   @default("ACTIVE")    // ACTIVE | INACTIVE | CONVERTED | TEMPORARILY_CLOSED | UNVERIFIED
  notes       String?
  contactInfo String?
  revenue     String?

  // ─── Prospect Intelligence Fields ──────────────────────────────────────────
  prospectId      String?           // CC-XXXX format from JSON data
  brandName       String?           // Parent brand name (e.g., "Chama Mama")
  category        String?           // GEO_REST | GEO_BAKERY | EE_MARKET | DISTRIBUTOR | etc.
  categoryLabel   String?           // Human-readable: "Georgian Restaurant", etc.
  tier            Int?              // 1-5 (Core to Experimental)
  tierLabel       String?           // CORE | ADJACENT | STRATEGIC | GROWTH | EXPERIMENTAL
  priorityScore   Float?            // 0-100 weighted composite score
  priorityRank    String?           // CRITICAL | HIGH | MEDIUM | LOW | EXPLORATORY

  // ─── Contact & Location Detail ─────────────────────────────────────────────
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  googleRating    Float?

  // ─── Revenue Model ─────────────────────────────────────────────────────────
  revenueMonthlyLow   Int?          // USD low estimate per location
  revenueMonthlyHigh  Int?          // USD high estimate per location
  cheeseLbsLow        Int?          // lbs/month low
  cheeseLbsHigh       Int?          // lbs/month high

  // ─── Logistics ─────────────────────────────────────────────────────────────
  distanceMiles   Float?            // from Columbus, OH
  driveHours      Float?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])
}

// ─── DashboardAccess ─────────────────────────────────────────────────────────
// Admin-controlled per-user access to analytics

model DashboardAccess {
  id          String   @id @default(uuid())
  userId      String
  dashboard   String   @default("ANALYTICS")
  canView     Boolean  @default(true)
  canEdit     Boolean  @default(false)
  grantedBy   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SiteConfig ──────────────────────────────────────────────────────────────
// Key-value store for website content managed by admin/content manager

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── ProductReview ───────────────────────────────────────────────────────────
// D2C customer reviews & questions for products
// status: "PENDING" | "APPROVED" | "REJECTED"

model ProductReview {
  id                 String   @id @default(uuid())
  productId          String
  userId             String
  rating             Int      // 1-5
  title              String
  body               String
  isVerifiedPurchase Boolean  @default(false)
  status             String   @default("PENDING")
  adminNote          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos  ReviewPhoto[]
  replies ReviewReply[]

  @@unique([productId, userId])
}

// ─── ReviewPhoto ─────────────────────────────────────────────────────────────

model ReviewPhoto {
  id        String   @id @default(uuid())
  reviewId  String
  imageUrl  String
  createdAt DateTime @default(now())

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// ─── ReviewReply ─────────────────────────────────────────────────────────────
// Follow-up replies on reviews (by customer or admin)

model ReviewReply {
  id           String   @id @default(uuid())
  reviewId     String
  userId       String
  body         String
  isAdminReply Boolean  @default(false)
  createdAt    DateTime @default(now())

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Site Settings ──────────────────────────────────────────────────────────
// Key-value store for admin-configurable settings

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

