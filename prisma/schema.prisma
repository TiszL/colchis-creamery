// Colchis Food - Prisma Schema
// Georgian artisanal cheese & bakery e-commerce platform
// ─── Multi-Role RBAC Architecture ────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// Roles: MASTER_ADMIN | PRODUCT_MANAGER | CONTENT_MANAGER | SALES
//        B2B_PARTNER | B2C_CUSTOMER | ANALYTICS_VIEWER

model User {
  id                String     @id @default(uuid())
  // Phase 11: email is no longer globally unique — it's unique PER ROLE.
  // A real person can have one D2C identity AND one B2B identity sharing
  // an email; login flows scope by role to disambiguate. See @@unique below.
  email             String
  passwordHash      String?
  name              String?
  phone             String?    @unique
  avatarUrl         String?
  role              String     @default("B2C_CUSTOMER")
  companyName       String?
  stripeCustomerId  String?
  isActiveB2b       Boolean    @default(false)
  isActive          Boolean    @default(true)
  // Bumped to invalidate ALL of a user's existing JWT sessions at once (role
  // change, forced logout). getSession() rejects tokens whose sessionVersion
  // != the current value, so a demoted/fired user loses access immediately
  // instead of keeping a valid 7-day cookie.
  sessionVersion    Int        @default(0)
  emailVerified     Boolean    @default(false)
  verificationCode  String?
  verificationExpiry DateTime?
  twoFactorCode     String?
  twoFactorExpiry   DateTime?
  totpSecret        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  orders           Order[]
  contracts        Contract[]
  profile          UserProfile?
  dashboardAccess  DashboardAccess[]
  analyticsPins    AnalyticsPin[]
  accounts         Account[]
  reviews          ProductReview[]
  reviewReplies    ReviewReply[]
  addresses        UserAddress[]
  chatSessionsAsVisitor ChatSession[] @relation("ChatVisitor")
  chatSessionsAsAgent   ChatSession[] @relation("ChatAgent")
  refundsInitiated      Refund[]
  // Phase 2: per-location operator roles. Additive to User.role (global
  // role like MASTER_ADMIN / B2C_CUSTOMER is unchanged). A user can have
  // multiple roles at the same location and roles across locations.
  locationRoles         UserLocation[]
  // Phase 3: who initiated each stock movement (null = system/webhook-driven).
  stockMovements        StockMovement[]
  // Phase 6: B2B partner profile (1:1 with User when role=B2B_PARTNER) +
  // sales-manager assignments. Both nullable — a normal user has neither.
  b2bPartner            B2bPartner?
  b2bPartnersOwned      B2bPartner[]    @relation("AssignedSales")

  // Phase 11: scope email uniqueness to (email, role) so a person can hold
  // both a D2C and a B2B identity with the same address.
  @@unique([email, role])
}

// Phase 2 — Per-location operator roles. A user can hold multiple roles at
// one location (e.g. both LOCATION_MANAGER and LOCATION_FULFILLMENT) and
// roles across multiple locations (e.g. roving regional manager). MASTER_ADMIN
// bypasses this table entirely (sees + does everything via global role).
enum LocationRole {
  LOCATION_MANAGER       // edit location's menu, set stock, all order fulfillment
  LOCATION_FULFILLMENT   // order queue access: mark prepping / ready / out / delivered
  B2B_SALES_MANAGER      // B2B order pipeline + partner ops for this warehouse
}

model UserLocation {
  id          String       @id @default(uuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  role        LocationRole
  createdAt   DateTime     @default(now())

  @@unique([userId, locationId, role])
  @@index([userId])
  @@index([locationId])
}

// ─── Phase 6 — B2B platform ──────────────────────────────────────────────────
//
// B2bPartner: operational profile attached 1:1 to a User with role=B2B_PARTNER.
// Holds wholesale-specific data + the Resolve customer link for net-terms
// invoicing + the assigned sales manager. Contract (Adobe Sign) and existing
// User.role / User.companyName fields stay as-is for backwards compat; new
// B2B work reads from B2bPartner.

enum B2bPaymentMethod {
  STRIPE_CARD       // pay-now via Stripe credit card
  STRIPE_ACH        // pay-now via Stripe ACH (slower, lower fee)
  RESOLVE_NET_7
  RESOLVE_NET_15
  RESOLVE_NET_30
  RESOLVE_NET_45
}

enum B2bInvoiceStatus {
  PENDING       // issued, awaiting payment / collection
  PAID          // partner paid in full
  OVERDUE       // past dueAt, no payment received
  WRITTEN_OFF   // collection abandoned
}

model B2bPartner {
  id                       String    @id @default(uuid())
  userId                   String    @unique
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Operational profile (extends User.companyName).
  companyName              String
  businessAddress          String?
  ein                      String?   // US tax ID, optional

  // Sales-tax exemption (resale). Wholesale-for-resale is tax-exempt ONLY with a
  // valid resale certificate on file; these store that compliance record so the
  // tax-exempt B2B pricing can be justified in an audit.
  taxExempt                    Boolean   @default(false)
  resaleCertificateNumber      String?
  resaleCertificateState       String?
  resaleCertificateExpiresAt   DateTime?
  resaleCertificateUrl         String?   // link to the uploaded certificate doc

  // Resolve net-terms integration. Customer ID is created on first net-terms
  // attempt (just-in-time, not on partner signup). Credit limit is cached
  // from Resolve and refreshed by the credit-check pull.
  resolveCustomerId        String?
  resolveCreditLimitCents  Int?
  resolveCreditApproved    Boolean   @default(false)
  resolveStatusUpdatedAt   DateTime?

  // Sales relationship — which sales manager owns this partner.
  assignedSalesUserId      String?
  assignedSales            User?     @relation("AssignedSales", fields: [assignedSalesUserId], references: [id])

  // Default fulfillment preference: which warehouse this partner usually
  // pulls from. Sales/ops can override per-order. Null = ops decides.
  defaultFulfillmentLocationId String?
  defaultFulfillmentLocation   Location? @relation("B2bPartnerDefaultLocation", fields: [defaultFulfillmentLocationId], references: [id])

  notes                    String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  invoices                 B2bInvoice[]
  schedules                RecurringOrderSchedule[]

  @@index([assignedSalesUserId])
}

// B2bInvoice is created when an order is placed with payment method =
// RESOLVE_NET_*. Stripe pay-now orders (CARD/ACH) skip the invoice — they
// go straight to PAID via the existing Stripe webhook path. paymentMethod
// is stored so the dispatch queue + sales dashboard can filter.
model B2bInvoice {
  id                String           @id @default(uuid())
  orderId           String           @unique
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partnerId         String
  partner           B2bPartner       @relation(fields: [partnerId], references: [id])

  amountCents       Int
  paymentMethod     B2bPaymentMethod

  // Resolve linkage when paymentMethod ∈ RESOLVE_NET_*.
  resolveInvoiceId  String?
  resolveStatus     String?
  resolvePayUrl     String?          // persisted Resolve hosted pay link, re-shown to the partner

  issuedAt          DateTime         @default(now())
  dueAt             DateTime?        // null for STRIPE_* — pay-now has no due date
  paidAt            DateTime?

  status            B2bInvoiceStatus @default(PENDING)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([partnerId, status])
  @@index([status, dueAt])           // AR-aging queries
}

// Partner sets up "every Tuesday: 5× sulguni, 2× imeruli" and the cron
// auto-creates draft Orders on schedule. Partner can edit before cutoff.
model RecurringOrderSchedule {
  id              String       @id @default(uuid())
  partnerId       String
  partner         B2bPartner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  name            String       // partner-given label ("Weekly sulguni")
  active          Boolean      @default(true)

  // Cadence — interval days from last fire. 7 = weekly, 14 = biweekly, 30 = monthly.
  // Kept simple (no cron expressions) so partner UI is trivial.
  intervalDays    Int
  nextFireAt      DateTime

  // Cart contents stored as JSON array of { productId, quantity }.
  // Edited inline on the partner schedule page.
  itemsJson       String

  paymentMethod   B2bPaymentMethod

  // Pin to a specific warehouse, or null = use partner.defaultFulfillmentLocationId.
  fulfillmentLocationId String?
  fulfillmentLocation   Location? @relation("RecurringScheduleLocation", fields: [fulfillmentLocationId], references: [id])

  lastFiredAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([active, nextFireAt])
  @@index([partnerId])
}

// ─── Phase 3 — Inventory: lot/batch tracking + movement audit log ────────────
//
// `Stock` (Phase 1) stays as the per-(location, product) aggregate for fast
// catalog reads. `ProductBatch` decomposes that aggregate into individual
// lots so we can track expiry + manufacturing dates per food safety rules.
// FIFO sales (3d) consume the soonest-expiring active batch first.
//
// `StockMovement` is the append-only audit log of every change: receives,
// transfers, sales, adjustments, waste. Always written in the same Prisma
// transaction as the Stock + ProductBatch updates so the log can't drift.

enum StockMovementType {
  RECEIVE        // new batch received from manufacturer / supplier
  TRANSFER_OUT   // batch (or partial) sent to another location
  TRANSFER_IN    // batch (or partial) received from another location
  SALE           // consumed by a paid customer order (FIFO across batches)
  RESERVE        // held against a pending order (released or converted to SALE)
  RELEASE        // reservation cancelled, returned to available pool
  ADJUSTMENT     // manual correction by staff (positive or negative)
  WASTE          // spoilage, damage, or expired stock removed
}

model ProductBatch {
  id              String    @id @default(uuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId      String
  location        Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lotNumber       String?              // optional human-readable lot ID ("SUL-2026W21-A")
  manufacturedAt  DateTime?            // null = unknown (e.g. backfilled pre-existing stock)
  expiresAt       DateTime?            // null = no expiry / shelf-stable
  quantity        Int                  // current quantity in this batch (mutates)
  initialQuantity Int                  // original quantity at receipt (immutable for traceability)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movements       StockMovement[]

  @@index([productId, locationId])
  @@index([locationId, expiresAt])      // expiry watchlist queries
}

model StockMovement {
  id              String            @id @default(uuid())
  // Batch is optional — receives + adjustments always have one; SALE/TRANSFER
  // entries may either reference a specific batch (the one consumed) or be
  // null when batches aren't being tracked yet for that SKU.
  batchId         String?
  batch           ProductBatch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  // Denormalized for efficient timeline queries without joining batch.
  productId       String
  product         Product           @relation(fields: [productId], references: [id])
  locationId      String
  location        Location          @relation(fields: [locationId], references: [id])
  type            StockMovementType
  // Signed: positive for RECEIVE / TRANSFER_IN / RELEASE / positive ADJUSTMENT;
  // negative for SALE / TRANSFER_OUT / WASTE / RESERVE / negative ADJUSTMENT.
  quantityDelta   Int
  fromLocationId  String?           // populated for TRANSFER_OUT / TRANSFER_IN
  toLocationId    String?
  orderId         String?           // populated for SALE / RESERVE / RELEASE — no FK so Order delete doesn't break audit
  initiatedByUserId String?         // null = system (webhook-driven SALE, expiry sweep, etc.)
  initiatedBy     User?             @relation(fields: [initiatedByUserId], references: [id])
  reason          String?           // optional free-text (e.g. ADJUSTMENT rationale)
  createdAt       DateTime          @default(now())

  @@index([productId, locationId, createdAt])
  @@index([orderId])
  @@index([type, createdAt])
}

// ─── UserAddress ─────────────────────────────────────────────────────────────
// Multiple shipping/delivery addresses per user, geocoded for radius lookups.

model UserAddress {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?              // "Home" | "Work" | "Mom's" — free text
  addressLine1  String
  addressLine2  String?              // apartment / suite / unit
  city          String
  state         String
  postalCode    String
  country       String   @default("US")
  latitude      Float?
  longitude     Float?
  googlePlaceId String?
  isDefault     Boolean  @default(false)
  // Phase B: extended delivery details, all optional. Carriers (DD/Uber) use
  // these as dropoff_instructions / dropoff_notes so drivers can find the door.
  accessCode      String?              // gate / buzzer / lockbox code
  buildingName    String?              // "The Wexley", "Tower B", etc.
  deliveryNotes   String?              // free-text — "leave at door", "side entrance"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── UserProfile ─────────────────────────────────────────────────────────────
// Extended profile for B2C customers (shipping, billing)

model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  shippingAddress   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?  @default("US")
  billingAddress    String?
  billingCity       String?
  billingState      String?
  billingZip        String?
  billingCountry    String?  @default("US")
  preferredLanguage String?  @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ProductLine ─────────────────────────────────────────────────────────────
// Two primary lines: RESERVE (LTLT) and CLASSIC (HTST)

model ProductLine {
  id            String      @id @default(uuid())
  slug          String      @unique   // "reserve" | "classic"
  name          String                // "Colchis Reserve™" | "Colchis Classic"
  tagline       String?               // "Slow Pasteurized / LTLT / Premium Artisanal"
  description   String?               // Full marketing description
  badgeColor    String?     @default("#CBA153") // UI accent color
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  categories    Category[]
  products      Product[]
}

// ─── Category ────────────────────────────────────────────────────────────────
// Categories within each product line (e.g., "Pulled-Curd Cheese", "Whey Spread")

model Category {
  id              String       @id @default(uuid())
  slug            String       @unique
  name            String                  // "Pulled-Curd Cheese" | "Drinks" | "Hot Pastries"
  description     String?
  imageUrl        String?                 // Category hero/icon image
  // Phase 9a: ProductLine relation is now optional. Categories can live
  // independently ("Drinks") without being chained under a marketing tier.
  productLineId   String?
  // Phase 9a: which storefront sections this category appears on.
  // Values: "creamery" | "bakery" | "shop" | "wholesale". A category may
  // appear on multiple sections — e.g. a "Drinks" category could be
  // tagged ["bakery"] (cafe drinks) or ["bakery", "creamery"] (also
  // cultured drinks like kefir).
  sections        String[]    @default([])
  // Phase 9b: replaces the dropped ProductKind enum for shipping packaging.
  // Values: "HOT" | "COLD" | "AMBIENT". Null = AMBIENT (no special handling).
  // shipping.ts uses this to pick HOT_INSULATED / INSULATED_COLD_CHAIN / AMBIENT
  // packaging for DoorDash/Uber routes. Admin sets per-category in CategoryManager.
  packagingMode   String?
  sortOrder       Int         @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  productLine     ProductLine? @relation(fields: [productLineId], references: [id])
  products        Product[]
}

// ─── Product ─────────────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

// SalesChannel is the catalog/business-line axis. Every Product (SKU) belongs
// to exactly one. Combined with Location.allowsChannels, it gates which
// products a location can offer. Orthogonal to DeliveryMethod (which
// describes HOW the order moves — DoorDash, UPS, pickup, etc.).
enum SalesChannel {
  LOCAL_HOT      // hot bakery food, made-to-order, same-day
  LOCAL_COLD     // cheese/cold items sold via local delivery or pickup
  NATIONAL_SHIP  // cold-pack 2-day shipping from cold warehouse
  B2B_WHOLESALE  // bulk cheese/butter for wholesale partners
  B2B_FROZEN     // frozen ready-to-bake products for B2B
}

// ─── ProductFamily ───────────────────────────────────────────────────────────
// Customer-facing grouping. One physical product ("Sulguni") can have
// multiple Product SKUs across SalesChannels with different packaging, price,
// and stock pools. The Family is the shared display name + hero copy.

model ProductFamily {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String                  // "Sulguni"
  displayName String?                 // optional storefront override
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

model Product {
  id             String        @id @default(uuid())
  sku            String        @unique
  name           String
  nameKa         String?       // Georgian localized name, e.g. "აჭარული"
  slug           String        @unique
  description    String
  flavorProfile  String?
  pairsWith      String?
  weight         String?
  ingredients    String?
  imageUrl       String
  images         String[]      @default([])
  videoUrls      String[]      @default([])
  priceB2c       String
  priceB2b       String
  stockQuantity  Int           // legacy: cached total. Stock per location is in Stock[].
  // Phase 9b: ProductKind enum + legacy `category` String dropped.
  // Classification is now: salesChannel (catalog axis) + categoryId (taxonomy,
  // free-form via Category model) + productFamilyId (cross-channel SKU grouping).
  isMadeToOrder  Boolean       @default(false) // true => no stock tracking at location (e.g. hot khachapuri)
  tag            String?       // Optional UI badge: "Bestseller" | "Vegan" | "Limited" | "Ships" | etc.
  productLineId  String?
  // Phase 9b: categoryId is now required. Every Product belongs to exactly
  // one Category which drives storefront section routing + packaging mode.
  categoryId     String
  status         ProductStatus @default(ACTIVE)
  isActive       Boolean       @default(true)
  isB2cVisible   Boolean       @default(true)
  isB2bVisible   Boolean       @default(true)
  // Phase 10: surfaces an "Add to cart" vs "Wholesale request" gate without
  // hiding the product. B2B-only items keep isB2cVisible=true + isCartOrderable=false
  // so they appear in /shop with a "Wholesale only" CTA instead of disappearing.
  isCartOrderable Boolean      @default(true)
  // Phase 1 (channel model). Populated by 1c backfill; tightened to NOT NULL.
  // salesChannel default lets seed/CMS callers omit it; admin UI in 1d makes
  // it an explicit choice. Pick LOCAL_COLD because the historical kind=
  // CREAMERY_CHEESE default already mapped to LOCAL_COLD.
  productFamilyId String
  salesChannel    SalesChannel  @default(LOCAL_COLD)
  // Packaging required for this SKU. Free text so admin can introduce
  // new packaging types without a schema change. Example values:
  // 'retail-pouch' | 'cold-pack-2day' | 'wholesale-case' | 'frozen-bulk' | 'hot-bag'
  packagingType   String?
  // COGS per unit (same string-money convention as priceB2c). Used by
  // reporting/margin dashboards (Phase 7). Null = not yet recorded.
  unitCost        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  productLine    ProductLine?    @relation(fields: [productLineId], references: [id])
  productCategory Category       @relation(fields: [categoryId], references: [id])
  productFamily  ProductFamily   @relation(fields: [productFamilyId], references: [id])
  orderItems     OrderItem[]
  reviews        ProductReview[]
  stocks         Stock[]
  batches        ProductBatch[]
  stockMovements StockMovement[]
}

// ─── Contract ────────────────────────────────────────────────────────────────
// status: "PENDING" | "OUT_FOR_SIGNATURE" | "SIGNED" | "EXPIRED"

model Contract {
  id                     String    @id @default(uuid())
  partnerId              String
  adobeSignAgreementId   String?
  status                 String    @default("PENDING")
  signedDocumentUrl      String?
  discountPercentage     String    @default("0")
  validUntil             DateTime?
  createdAt              DateTime  @default(now())

  partner User @relation(fields: [partnerId], references: [id])
}

// ─── Order ───────────────────────────────────────────────────────────────────
// orderType: "B2C" | "B2B"
// paymentStatus: "UNPAID" | "PAID" | "REFUNDED"
// orderStatus: "PROCESSING" | "READY_FOR_PICKUP" | "SHIPPED" | "IN_TRANSIT" | "DELIVERED"

model Order {
  id                     String      @id @default(uuid())
  userId                 String
  orderType              String      @default("B2C")
  totalAmount            String
  // Phase 7a — monetary breakdown (kept as strings to match existing money convention)
  subtotalAmount         String?     // items × qty before shipping/tax
  shippingAmount         String?     // sum of OrderFulfillment.shippingCost
  taxAmount              String?     // total tax (Stripe Tax computed)
  // Phase 7a — guest checkout. Order.userId still required; we create User rows
  // with passwordHash=null for guests. Email/phone duplicated here for fast lookup
  // independent of the User row (also helps cross-user-merge later).
  guestEmail             String?
  guestPhone             String?
  // Phase 7a — scheduled fulfillment (earliest "ready" time across all fulfillments)
  scheduledFor           DateTime?
  // Phase 7a — auto-release reserved stock if payment doesn't complete in time
  reservationExpiresAt   DateTime?
  stripePaymentIntentId  String?     @unique  // used for idempotency on webhooks
  stripeInvoiceId        String?
  // Phase 7a.6 — Stripe Tax integration.
  // calculation id is set in 7a.5 right after we call tax.calculations.create.
  // transaction id is set in 7a.6 webhook after createFromCalculation succeeds.
  // Admin tooling (7b) can find orders with calculation but no transaction to retry.
  stripeTaxCalculationId String?
  stripeTaxTransactionId String?
  paymentStatus          String      @default("UNPAID")
  orderStatus            String      @default("PROCESSING")
  shippingAddress        String?
  shippingLat            Float?
  shippingLng            Float?
  // Phase 9c: structured snapshot of shipping address at order time.
  // Replaces the lossy parser in lib/shipping.ts uber-direct dispatch path.
  // Readers prefer these when present; fall back to parsing shippingAddress
  // for older rows (pre-9c) that only have the free-text snapshot.
  shippingLine1          String?
  shippingCity           String?
  shippingState          String?
  shippingPostalCode     String?
  // Phase B: address-detail snapshot at order time (so future UserAddress
  // edits/deletes don't mutate historical orders). All optional; carriers use
  // these to populate dropoff_instructions / dropoff_notes for the driver.
  shippingAddressLine2   String?
  shippingAccessCode     String?
  shippingBuildingName   String?
  shippingDeliveryNotes  String?
  notes                  String?
  createdAt              DateTime    @default(now())

  user         User              @relation(fields: [userId], references: [id])
  orderItems   OrderItem[]
  shipment     Shipment?
  fulfillments OrderFulfillment[]
  refunds      Refund[]
  // Phase 6 — B2B invoice when paymentMethod ∈ RESOLVE_NET_*.
  b2bInvoice   B2bInvoice?

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
}

// ─── OrderItem ───────────────────────────────────────────────────────────────

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice String

  order            Order                  @relation(fields: [orderId], references: [id])
  product          Product                @relation(fields: [productId], references: [id])
  fulfillmentItems OrderFulfillmentItem[]

  @@index([orderId])
  @@index([productId])
}

// ─── ProcessedStripeEvent ──────────────────────────────────────────────────────
// Event-level idempotency for the Stripe webhook. PK = the Stripe event.id, so a
// duplicate delivery/retry conflicts on insert and the handler short-circuits.
model ProcessedStripeEvent {
  id          String   @id
  type        String?
  processedAt DateTime @default(now())
}

// ─── Shipment ────────────────────────────────────────────────────────────────

model Shipment {
  id                    String    @id @default(uuid())
  orderId               String    @unique
  carrierName           String?
  trackingNumber        String?
  dispatchDate          DateTime?
  estimatedDeliveryDate DateTime?
  deliveryAddress       String?
  createdAt             DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// ─── B2bLead ─────────────────────────────────────────────────────────────────
// status: "NEW" | "CONTACTED" | "CONVERTED" | "REJECTED"

model B2bLead {
  id             String   @id @default(uuid())
  companyName    String
  contactName    String?
  email          String
  phone          String?
  address        String?
  expectedVolume String?
  message        String?
  status         String   @default("NEW")
  assignedTo     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Recipe ──────────────────────────────────────────────────────────────────

model Recipe {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  content       String
  contentBlocks String?  // JSON array of content blocks
  prepTime      String?
  cookTime      String?
  servings      String?
  difficulty    String?
  imageUrl      String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Article ─────────────────────────────────────────────────────────────────
// CMS-managed blog/news articles

model Article {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String
  contentBlocks String?  // JSON array of content blocks
  coverImage    String?
  authorId      String?
  tags          String?
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── AccessCode ──────────────────────────────────────────────────────────────
// type: "B2B" | "STAFF" | "ANALYTICS_VIEWER"
// targetRole: The role assigned when the code is redeemed

model AccessCode {
  id         String    @id @default(uuid())
  code       String    @unique
  type       String    @default("B2B")
  targetRole String    @default("B2B_PARTNER")
  email      String?
  isUsed     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  // Phase 11: staged email-change. When a partner tries to register with an
  // email different from `email` (the address the invite was sent to), we
  // don't reject — we store the new address here + a confirmation token,
  // and email the ORIGINAL address asking them to approve. Clicking confirm
  // updates `email = pendingEmail` and clears these fields, unlocking
  // registration for the new address.
  pendingEmail            String?
  pendingEmailToken       String?  @unique
  pendingEmailExpiresAt   DateTime?
  pendingEmailRequestedAt DateTime?
}

// ─── AnalyticsPin ────────────────────────────────────────────────────────────
// Google Maps markers for business development

model AnalyticsPin {
  id          String   @id @default(uuid())
  name        String
  latitude    Float
  longitude   Float
  pinType     String   @default("PROSPECT")  // PROSPECT | PARTNER | SUPPLIER | ZONE
  status      String   @default("ACTIVE")    // ACTIVE | INACTIVE | CONVERTED | TEMPORARILY_CLOSED | UNVERIFIED
  notes       String?
  contactInfo String?
  revenue     String?

  // ─── Prospect Intelligence Fields ──────────────────────────────────────────
  prospectId      String?           // CC-XXXX format from JSON data
  brandName       String?           // Parent brand name (e.g., "Chama Mama")
  category        String?           // GEO_REST | GEO_BAKERY | EE_MARKET | DISTRIBUTOR | etc.
  categoryLabel   String?           // Human-readable: "Georgian Restaurant", etc.
  tier            Int?              // 1-5 (Core to Experimental)
  tierLabel       String?           // CORE | ADJACENT | STRATEGIC | GROWTH | EXPERIMENTAL
  priorityScore   Float?            // 0-100 weighted composite score
  priorityRank    String?           // CRITICAL | HIGH | MEDIUM | LOW | EXPLORATORY

  // ─── Contact & Location Detail ─────────────────────────────────────────────
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  googleRating    Float?

  // ─── Revenue Model ─────────────────────────────────────────────────────────
  revenueMonthlyLow   Int?          // USD low estimate per location
  revenueMonthlyHigh  Int?          // USD high estimate per location
  cheeseLbsLow        Int?          // lbs/month low
  cheeseLbsHigh       Int?          // lbs/month high

  // ─── Logistics ─────────────────────────────────────────────────────────────
  distanceMiles   Float?            // from Columbus, OH
  driveHours      Float?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])
}

// ─── DashboardAccess ─────────────────────────────────────────────────────────
// Admin-controlled per-user access to analytics

model DashboardAccess {
  id          String   @id @default(uuid())
  userId      String
  dashboard   String   @default("ANALYTICS")
  canView     Boolean  @default(true)
  canEdit     Boolean  @default(false)
