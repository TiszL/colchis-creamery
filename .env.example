# Database
DATABASE_URL="file:./prisma/dev.db"

# Authentication
JWT_SECRET="your-secret-key-change-in-production"

# Stripe (PLACEHOLDER - set when company is established)
STRIPE_SECRET_KEY="sk_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
STRIPE_PUBLISHABLE_KEY="pk_placeholder"

# Adobe Sign (PLACEHOLDER - set when account is created)
ADOBE_ACCESS_TOKEN="placeholder"
ADOBE_B2B_TEMPLATE_ID="placeholder"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

#resend api

RESEND_API_KEY=
EMAIL_FROM=updates@noreply.colchisfood.com

# Optional: BCC recipient for order confirmation emails (e.g. bakery ops).
# Unset = no BCC, customer is the only recipient.
BAKERY_NOTIFICATION_EMAIL=

# Cron job authorization (Phase 7b.1+).
# Vercel sends `Authorization: Bearer <value>` to /api/cron/* endpoints.
# Generate a strong random string for production.
CRON_SECRET=

# Secret for HS256-signing guest order-lookup tokens (Phase 7b.3).
# Used by /orders/<token> public route reached from the confirmation email.
# If unset, falls back to JWT_SECRET — set separately in production so a
# session-secret leak doesn't compromise order-lookup tokens.
ORDER_LOOKUP_SECRET=

# DoorDash Drive carrier integration (Phase 8.1).
# Get these from the DoorDash Developer Portal — same keys for sandbox + prod;
# environment is determined by which key set you use.
# All three must be set together; if any is missing, the DOORDASH_DRIVE channel
# falls back to LocationChannel.flatFee at quote time and no delivery is dispatched.
DOORDASH_DEVELOPER_ID=
DOORDASH_KEY_ID=
DOORDASH_SIGNING_SECRET=
# Override the API base URL if you're using a regional / private endpoint.
# Default: https://openapi.doordash.com
DOORDASH_API_BASE=

# Uber Direct carrier integration (Phase 8.2).
# Get these from the Uber Developer Portal (Direct API). Use sandbox keys for
# testing; switch UBER_DIRECT_API_BASE to https://sandbox-api.uber.com if your
# sandbox is on a different host.
# All three required env vars must be set together; otherwise UBER_DIRECT
# channel falls back to LocationChannel.flatFee at quote time.
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
UBER_DIRECT_CUSTOMER_ID=
# Webhook signing secret — separate from client_secret. Set in Uber's webhook
# config. If unset, the webhook accepts unsigned requests (dev convenience).
UBER_DIRECT_WEBHOOK_SECRET=
# Override the API base URL if you're using sandbox (https://sandbox-api.uber.com)
# or a different region. Default: https://api.uber.com
UBER_DIRECT_API_BASE=
# OAuth token endpoint. Default works for both sandbox + production.
# Default: https://login.uber.com/oauth/v2/token
UBER_DIRECT_TOKEN_URL=

# Vercel Blob Storage (for image/video uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_token_here"
