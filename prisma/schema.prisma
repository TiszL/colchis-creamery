// Colchis Food - Prisma Schema
// Georgian artisanal cheese & bakery e-commerce platform
// ─── Multi-Role RBAC Architecture ────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// Roles: MASTER_ADMIN | PRODUCT_MANAGER | CONTENT_MANAGER | SALES
//        B2B_PARTNER | B2C_CUSTOMER | ANALYTICS_VIEWER

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String?
  name              String?
  phone             String?    @unique
  avatarUrl         String?
  role              String     @default("B2C_CUSTOMER")
  companyName       String?
  stripeCustomerId  String?
  isActiveB2b       Boolean    @default(false)
  isActive          Boolean    @default(true)
  emailVerified     Boolean    @default(false)
  verificationCode  String?
  verificationExpiry DateTime?
  twoFactorCode     String?
  twoFactorExpiry   DateTime?
  totpSecret        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  orders           Order[]
  contracts        Contract[]
  profile          UserProfile?
  dashboardAccess  DashboardAccess[]
  analyticsPins    AnalyticsPin[]
  accounts         Account[]
  reviews          ProductReview[]
  reviewReplies    ReviewReply[]
  addresses        UserAddress[]
  chatSessionsAsVisitor ChatSession[] @relation("ChatVisitor")
  chatSessionsAsAgent   ChatSession[] @relation("ChatAgent")
  refundsInitiated      Refund[]
}

// ─── UserAddress ─────────────────────────────────────────────────────────────
// Multiple shipping/delivery addresses per user, geocoded for radius lookups.

model UserAddress {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String?              // "Home" | "Work" | "Mom's" — free text
  addressLine1  String
  addressLine2  String?              // apartment / suite / unit
  city          String
  state         String
  postalCode    String
  country       String   @default("US")
  latitude      Float?
  longitude     Float?
  googlePlaceId String?
  isDefault     Boolean  @default(false)
  // Phase B: extended delivery details, all optional. Carriers (DD/Uber) use
  // these as dropoff_instructions / dropoff_notes so drivers can find the door.
  accessCode      String?              // gate / buzzer / lockbox code
  buildingName    String?              // "The Wexley", "Tower B", etc.
  deliveryNotes   String?              // free-text — "leave at door", "side entrance"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── UserProfile ─────────────────────────────────────────────────────────────
// Extended profile for B2C customers (shipping, billing)

model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  shippingAddress   String?
  shippingCity      String?
  shippingState     String?
  shippingZip       String?
  shippingCountry   String?  @default("US")
  billingAddress    String?
  billingCity       String?
  billingState      String?
  billingZip        String?
  billingCountry    String?  @default("US")
  preferredLanguage String?  @default("en")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ProductLine ─────────────────────────────────────────────────────────────
// Two primary lines: RESERVE (LTLT) and CLASSIC (HTST)

model ProductLine {
  id            String      @id @default(uuid())
  slug          String      @unique   // "reserve" | "classic"
  name          String                // "Colchis Reserve™" | "Colchis Classic"
  tagline       String?               // "Slow Pasteurized / LTLT / Premium Artisanal"
  description   String?               // Full marketing description
  badgeColor    String?     @default("#CBA153") // UI accent color
  sortOrder     Int         @default(0)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  categories    Category[]
  products      Product[]
}

// ─── Category ────────────────────────────────────────────────────────────────
// Categories within each product line (e.g., "Pulled-Curd Cheese", "Whey Spread")

model Category {
  id              String      @id @default(uuid())
  slug            String      @unique
  name            String                // "Pulled-Curd Cheese"
  description     String?
  imageUrl        String?               // Category hero/icon image
  productLineId   String
  sortOrder       Int         @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  productLine     ProductLine @relation(fields: [productLineId], references: [id])
  products        Product[]
}

// ─── Product ─────────────────────────────────────────────────────────────────

enum ProductStatus {
  ACTIVE
  INACTIVE
  COMING_SOON
}

// Classification for admin/UI grouping. Routing/eligibility decisions are
// driven by ProductChannel and Stock, not by this enum.
enum ProductKind {
  CREAMERY_CHEESE
  CREAMERY_BUTTER
  CREAMERY_SPREAD
  CREAMERY_OTHER
  BAKERY_HOT
  BAKERY_FROZEN
  BAKERY_PASTRY
  BAKERY_BREAD
}

// SalesChannel is the catalog/business-line axis. Every Product (SKU) belongs
// to exactly one. Combined with Location.allowsChannels, it gates which
// products a location can offer. Orthogonal to DeliveryMethod (which
// describes HOW the order moves — DoorDash, UPS, pickup, etc.).
enum SalesChannel {
  LOCAL_HOT      // hot bakery food, made-to-order, same-day
  LOCAL_COLD     // cheese/cold items sold via local delivery or pickup
  NATIONAL_SHIP  // cold-pack 2-day shipping from cold warehouse
  B2B_WHOLESALE  // bulk cheese/butter for wholesale partners
  B2B_FROZEN     // frozen ready-to-bake products for B2B
}

// ─── ProductFamily ───────────────────────────────────────────────────────────
// Customer-facing grouping. One physical product ("Sulguni") can have
// multiple Product SKUs across SalesChannels with different packaging, price,
// and stock pools. The Family is the shared display name + hero copy.

model ProductFamily {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String                  // "Sulguni"
  displayName String?                 // optional storefront override
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]
}

model Product {
  id             String        @id @default(uuid())
  sku            String        @unique
  name           String
  nameKa         String?       // Georgian localized name, e.g. "აჭარული"
  slug           String        @unique
  description    String
  flavorProfile  String?
  pairsWith      String?
  weight         String?
  ingredients    String?
  imageUrl       String
  images         String[]      @default([])
  videoUrls      String[]      @default([])
  priceB2c       String
  priceB2b       String
  stockQuantity  Int           // legacy: cached total. Stock per location is in Stock[].
  category       String?       @default("cheese")
  house          String?       @default("CREAMERY") // legacy: superseded by `kind`. Will be dropped after migration.
  kind           ProductKind   @default(CREAMERY_CHEESE)
  isMadeToOrder  Boolean       @default(false) // true => no stock tracking at location (e.g. hot khachapuri)
  tag            String?       // Optional UI badge: "Bestseller" | "Vegan" | "Limited" | "Ships" | etc.
  productLineId  String?
  categoryId     String?
  status         ProductStatus @default(ACTIVE)
  isActive       Boolean       @default(true)
  isB2cVisible   Boolean       @default(true)
  isB2bVisible   Boolean       @default(true)
  // Phase 10: surfaces an "Add to cart" vs "Wholesale request" gate without
  // hiding the product. B2B-only items keep isB2cVisible=true + isCartOrderable=false
  // so they appear in /shop with a "Wholesale only" CTA instead of disappearing.
  isCartOrderable Boolean      @default(true)
  // Phase 1 (channel model). Populated by 1c backfill; tightened to NOT NULL.
  // salesChannel default lets seed/CMS callers omit it; admin UI in 1d makes
  // it an explicit choice. Pick LOCAL_COLD because the historical kind=
  // CREAMERY_CHEESE default already mapped to LOCAL_COLD.
  productFamilyId String
  salesChannel    SalesChannel  @default(LOCAL_COLD)
  // Packaging required for this SKU. Free text so admin can introduce
  // new packaging types without a schema change. Example values:
  // 'retail-pouch' | 'cold-pack-2day' | 'wholesale-case' | 'frozen-bulk' | 'hot-bag'
  packagingType   String?
  // COGS per unit (same string-money convention as priceB2c). Used by
  // reporting/margin dashboards (Phase 7). Null = not yet recorded.
  unitCost        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  productLine    ProductLine?    @relation(fields: [productLineId], references: [id])
  productCategory Category?      @relation(fields: [categoryId], references: [id])
  productFamily  ProductFamily   @relation(fields: [productFamilyId], references: [id])
  orderItems     OrderItem[]
  reviews        ProductReview[]
  channels       ProductChannel[]
  stocks         Stock[]
}

// ─── Contract ────────────────────────────────────────────────────────────────
// status: "PENDING" | "OUT_FOR_SIGNATURE" | "SIGNED" | "EXPIRED"

model Contract {
  id                     String    @id @default(uuid())
  partnerId              String
  adobeSignAgreementId   String?
  status                 String    @default("PENDING")
  signedDocumentUrl      String?
  discountPercentage     String    @default("0")
  validUntil             DateTime?
  createdAt              DateTime  @default(now())

  partner User @relation(fields: [partnerId], references: [id])
}

// ─── Order ───────────────────────────────────────────────────────────────────
// orderType: "B2C" | "B2B"
// paymentStatus: "UNPAID" | "PAID" | "REFUNDED"
// orderStatus: "PROCESSING" | "READY_FOR_PICKUP" | "SHIPPED" | "IN_TRANSIT" | "DELIVERED"

model Order {
  id                     String      @id @default(uuid())
  userId                 String
  orderType              String      @default("B2C")
  totalAmount            String
  // Phase 7a — monetary breakdown (kept as strings to match existing money convention)
  subtotalAmount         String?     // items × qty before shipping/tax
  shippingAmount         String?     // sum of OrderFulfillment.shippingCost
  taxAmount              String?     // total tax (Stripe Tax computed)
  // Phase 7a — guest checkout. Order.userId still required; we create User rows
  // with passwordHash=null for guests. Email/phone duplicated here for fast lookup
  // independent of the User row (also helps cross-user-merge later).
  guestEmail             String?
  guestPhone             String?
  // Phase 7a — scheduled fulfillment (earliest "ready" time across all fulfillments)
  scheduledFor           DateTime?
  // Phase 7a — auto-release reserved stock if payment doesn't complete in time
  reservationExpiresAt   DateTime?
  stripePaymentIntentId  String?     @unique  // used for idempotency on webhooks
  stripeInvoiceId        String?
  // Phase 7a.6 — Stripe Tax integration.
  // calculation id is set in 7a.5 right after we call tax.calculations.create.
  // transaction id is set in 7a.6 webhook after createFromCalculation succeeds.
  // Admin tooling (7b) can find orders with calculation but no transaction to retry.
  stripeTaxCalculationId String?
  stripeTaxTransactionId String?
  paymentStatus          String      @default("UNPAID")
  orderStatus            String      @default("PROCESSING")
  shippingAddress        String?
  shippingLat            Float?
  shippingLng            Float?
  // Phase B: address-detail snapshot at order time (so future UserAddress
  // edits/deletes don't mutate historical orders). All optional; carriers use
  // these to populate dropoff_instructions / dropoff_notes for the driver.
  shippingAddressLine2   String?
  shippingAccessCode     String?
  shippingBuildingName   String?
  shippingDeliveryNotes  String?
  notes                  String?
  createdAt              DateTime    @default(now())

  user         User              @relation(fields: [userId], references: [id])
  orderItems   OrderItem[]
  shipment     Shipment?
  fulfillments OrderFulfillment[]
  refunds      Refund[]
}

// ─── OrderItem ───────────────────────────────────────────────────────────────

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice String

  order            Order                  @relation(fields: [orderId], references: [id])
  product          Product                @relation(fields: [productId], references: [id])
  fulfillmentItems OrderFulfillmentItem[]
}

// ─── Shipment ────────────────────────────────────────────────────────────────

model Shipment {
  id                    String    @id @default(uuid())
  orderId               String    @unique
  carrierName           String?
  trackingNumber        String?
  dispatchDate          DateTime?
  estimatedDeliveryDate DateTime?
  deliveryAddress       String?
  createdAt             DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// ─── B2bLead ─────────────────────────────────────────────────────────────────
// status: "NEW" | "CONTACTED" | "CONVERTED" | "REJECTED"

model B2bLead {
  id             String   @id @default(uuid())
  companyName    String
  contactName    String?
  email          String
  phone          String?
  address        String?
  expectedVolume String?
  message        String?
  status         String   @default("NEW")
  assignedTo     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Recipe ──────────────────────────────────────────────────────────────────

model Recipe {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  content       String
  contentBlocks String?  // JSON array of content blocks
  prepTime      String?
  cookTime      String?
  servings      String?
  difficulty    String?
  imageUrl      String?
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── Article ─────────────────────────────────────────────────────────────────
// CMS-managed blog/news articles

model Article {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String
  contentBlocks String?  // JSON array of content blocks
  coverImage    String?
  authorId      String?
  tags          String?
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─── AccessCode ──────────────────────────────────────────────────────────────
// type: "B2B" | "STAFF" | "ANALYTICS_VIEWER"
// targetRole: The role assigned when the code is redeemed

model AccessCode {
  id         String    @id @default(uuid())
  code       String    @unique
  type       String    @default("B2B")
  targetRole String    @default("B2B_PARTNER")
  email      String?
  isUsed     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
}

// ─── AnalyticsPin ────────────────────────────────────────────────────────────
// Google Maps markers for business development

model AnalyticsPin {
  id          String   @id @default(uuid())
  name        String
  latitude    Float
  longitude   Float
  pinType     String   @default("PROSPECT")  // PROSPECT | PARTNER | SUPPLIER | ZONE
  status      String   @default("ACTIVE")    // ACTIVE | INACTIVE | CONVERTED | TEMPORARILY_CLOSED | UNVERIFIED
  notes       String?
  contactInfo String?
  revenue     String?

  // ─── Prospect Intelligence Fields ──────────────────────────────────────────
  prospectId      String?           // CC-XXXX format from JSON data
  brandName       String?           // Parent brand name (e.g., "Chama Mama")
  category        String?           // GEO_REST | GEO_BAKERY | EE_MARKET | DISTRIBUTOR | etc.
  categoryLabel   String?           // Human-readable: "Georgian Restaurant", etc.
  tier            Int?              // 1-5 (Core to Experimental)
  tierLabel       String?           // CORE | ADJACENT | STRATEGIC | GROWTH | EXPERIMENTAL
  priorityScore   Float?            // 0-100 weighted composite score
  priorityRank    String?           // CRITICAL | HIGH | MEDIUM | LOW | EXPLORATORY

  // ─── Contact & Location Detail ─────────────────────────────────────────────
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  googleRating    Float?

  // ─── Revenue Model ─────────────────────────────────────────────────────────
  revenueMonthlyLow   Int?          // USD low estimate per location
  revenueMonthlyHigh  Int?          // USD high estimate per location
  cheeseLbsLow        Int?          // lbs/month low
  cheeseLbsHigh       Int?          // lbs/month high

  // ─── Logistics ─────────────────────────────────────────────────────────────
  distanceMiles   Float?            // from Columbus, OH
  driveHours      Float?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])
}

// ─── DashboardAccess ─────────────────────────────────────────────────────────
// Admin-controlled per-user access to analytics

model DashboardAccess {
  id          String   @id @default(uuid())
  userId      String
  dashboard   String   @default("ANALYTICS")
  canView     Boolean  @default(true)
  canEdit     Boolean  @default(false)
  grantedBy   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SiteConfig ──────────────────────────────────────────────────────────────
// Key-value store for website content managed by admin/content manager

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── ProductReview ───────────────────────────────────────────────────────────
// D2C customer reviews & questions for products
// status: "PENDING" | "APPROVED" | "REJECTED"

model ProductReview {
  id                 String   @id @default(uuid())
  productId          String
  userId             String
  rating             Int      // 1-5
  title              String
  body               String
  isVerifiedPurchase Boolean  @default(false)
  status             String   @default("PENDING")
  adminNote          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos  ReviewPhoto[]
  replies ReviewReply[]

  @@unique([productId, userId])
}

// ─── ReviewPhoto ─────────────────────────────────────────────────────────────

model ReviewPhoto {
  id        String   @id @default(uuid())
  reviewId  String
  imageUrl  String
  createdAt DateTime @default(now())

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

// ─── ReviewReply ─────────────────────────────────────────────────────────────
// Follow-up replies on reviews (by customer or admin)

model ReviewReply {
  id           String   @id @default(uuid())
  reviewId     String
  userId       String
  body         String
  isAdminReply Boolean  @default(false)
  createdAt    DateTime @default(now())

  review ProductReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Site Settings ──────────────────────────────────────────────────────────
// Key-value store for admin-configurable settings

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

// ─── ChatSession ────────────────────────────────────────────────────────────
// Live support chat sessions between visitors and staff
// status: "WAITING" | "ACTIVE" | "CLOSED"

model ChatSession {
  id            String    @id @default(uuid())
  visitorId     String                          // localStorage UUID for anonymous users
  visitorName   String?
  visitorEmail  String?
  userId        String?                         // FK → User (if visitor is logged in)
  assignedToId  String?                         // FK → User (staff who claimed session)
  status        String    @default("WAITING")   // WAITING | ACTIVE | CLOSED
  lastMessageAt DateTime  @default(now())
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user       User?         @relation("ChatVisitor", fields: [userId], references: [id])
  assignedTo User?         @relation("ChatAgent", fields: [assignedToId], references: [id])
  messages   ChatMessage[]

  @@index([status])
  @@index([assignedToId])
  @@index([visitorId])
}

// ─── ChatMessage ────────────────────────────────────────────────────────────
// Individual messages within a chat session
// sender: "visitor" | "agent" | "system"

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  sender    String                              // "visitor" | "agent" | "system"
  agentId   String?                             // FK → User (if sent by staff)
  body      String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ─── Multi-Location Fulfillment ──────────────────────────────────────────────
// A Location is a physical place that holds Stock for Products and offers one
// or more delivery Channels with their own radius / fee rules. Each Product can
// opt into specific Channels (ProductChannel); a Customer at lat/lng sees only
// products whose (Stock at L, Channel at L) reaches them.

enum LocationType {
  BAKERY              // hot bakery — local delivery + 3rd-party platforms + walk-in
  D2C_COLD_WAREHOUSE  // owned cold storage, UPS 2-day shipping
  B2B_3PL_WAREHOUSE   // third-party logistics for B2B cold chain (future)
}

// DeliveryMethod describes HOW an order moves (carrier, channel pricing,
// driver type). Orthogonal to SalesChannel (which describes WHAT business
// line the SKU belongs to). @@map keeps the underlying Postgres enum name
// as the legacy "DeliveryMethod" so this is a zero-data-migration rename.
enum DeliveryMethod {
  UPS_2DAY               @map("UPS_GROUND_2DAY")    // nationwide cold-chain via UPS 2nd Day Air (or FedEx 2Day fallback)
  OWN_DELIVERY           @map("HOT_DELIVERY_OWN")   // location's own drivers, short radius — used for hot food + local cheese
  DOORDASH_DRIVE         // DoorDash Drive API (our platform, lower fee)
  UBER_DIRECT            // Uber Direct API (our platform, lower fee)
  DOORDASH_MARKETPLACE   // listed on DoorDash app (higher fee, future)
  UBER_EATS_MARKETPLACE  // listed on Uber Eats app (higher fee, future)
  IN_STORE_PICKUP        // customer picks up at the bakery
  IN_STORE_DINE_IN       // customer eats at the bakery (e.g. hot khachapuri)
  MANUAL_DISPATCH        // B2B 3PL/freight booked manually by ops (Phase 6)

  @@map("DeliveryMethod")
}

model Location {
  id            String       @id @default(uuid())
  name          String                                // "Bakery — Dublin OH" / "Cold Warehouse — Columbus"
  type          LocationType
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  postalCode    String
  country       String       @default("US")
  latitude      Float?                                // populated via Google Places at admin save
  longitude     Float?
  googlePlaceId String?                               // store Place ID for re-lookup
  phone         String?
  hours         Json?                                 // { mon: "07:00-21:00", tue: "07:00-21:00", ... }
  isActive      Boolean      @default(true)
  notes         String?

  // Phase 10: display-layer fields. The Location table is the single source of
  // truth for both operational routing AND the brand-address shown across the
  // site (footer, homepage Visit, contact page, JSON-LD). Exactly one row is
  // isPrimary=true at a time; that row drives every "where do we read the brand
  // address" call via getPrimaryLocation().
  isPrimary             Boolean @default(false)
  showOnContactPage     Boolean @default(true)
  displayDescription    String?  // homepage Visit copy + contact card body
  displayBakeryHours    String?  // "Wed–Sun · 8a–9p" style short form
  contactCardName       String?  // vanity name shown on /contact, e.g. "The High St Counter"
  contactCardDoorNote   String?  // e.g. "Door 4 · ring twice"
  displayOrder          Int      @default(0)  // sort order for multi-location display on /contact

  // Phase 1: catalog channel allowlist. Which SalesChannels this location
  // handles. A bakery typically allows [LOCAL_HOT, LOCAL_COLD]; the cold
  // warehouse allows [NATIONAL_SHIP]; a B2B 3PL allows [B2B_WHOLESALE,
  // B2B_FROZEN]. Empty array by default; populated by 1c backfill from
  // LocationType, then admin-editable.
  allowsChannels        SalesChannel[]  @default([])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  channels     LocationDeliveryMethod[]
  stocks       Stock[]
  fulfillments OrderFulfillment[]
}

// Renamed from LocationChannel for clarity (the relation is one delivery
// method per location, with its own fee/radius config). @@map keeps the
// underlying Postgres table name as the legacy "LocationChannel" so the
// rename costs no data migration. Field `deliveryMethod` is @map'd to the
// legacy "channel" column for the same reason.
model LocationDeliveryMethod {
  id              String         @id @default(uuid())
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  deliveryMethod  DeliveryMethod @map("channel")
  radiusMiles     Float?                            // 25 for OWN_DELIVERY, ~1200 for UPS (20h drive); null = no radius gate
  maxDriveHours   Float?                            // alt to radiusMiles, used for UPS cold-chain
  flatFee         String?                           // dollars, stringly-typed to match Product.priceB2c convention
  perMileFee      String?                           // dollars per mile
  priceMultiplier Float          @default(1.0)      // 1.0 own platform, 1.3 marketplace markup
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([locationId, deliveryMethod], map: "LocationChannel_locationId_channel_key")
  @@map("LocationChannel")
}

model Stock {
  id                String   @id @default(uuid())
  locationId        String
  location          Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  productId         String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Int?                              // NULL = made-to-order (unlimited while location open)
  reservedQuantity  Int      @default(0)
  lowStockThreshold Int      @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@unique([locationId, productId])
  @@index([productId])
}

// Phase 1: superseded by Product.salesChannel + Location.allowsChannels.
// Dropped entirely in 1i. Field type updated so TS compiles in the
// intervening commit — no DB change here.
model ProductChannel {
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel   DeliveryMethod

  @@id([productId, channel])
  @@index([channel])
}

// One Order may split across multiple OrderFulfillment rows (one per location).
// Created at checkout time when checkout is implemented (Phase 7).

model OrderFulfillment {
  id                String             @id @default(uuid())
  orderId           String
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  locationId        String
  location          Location           @relation(fields: [locationId], references: [id])
  deliveryMethod    DeliveryMethod     @map("channel")
  status            String             @default("PENDING") // PENDING|CONFIRMED|PREPARING|OUT_FOR_DELIVERY|DELIVERED|CANCELLED
  trackingNumber    String?
  externalOrderId   String?                              // DoorDash/Uber Direct order id
  estimatedDelivery DateTime?
  shippingCost      String?
  // Phase 7a — scheduled fulfillment time (MTO hot food outside hours, or
  // customer-chosen later slot). Null means "as soon as possible".
  scheduledFor      DateTime?
  // Phase 7a — packaging requirement, e.g. "INSULATED_COLD_CHAIN" for UPS creamery.
  // Helps the kitchen/warehouse pick the right packaging.
  packagingType     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  items OrderFulfillmentItem[]

  @@index([orderId])
}

model OrderFulfillmentItem {
  id            String           @id @default(uuid())
  fulfillmentId String
  fulfillment   OrderFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItemId   String
  orderItem     OrderItem        @relation(fields: [orderItemId], references: [id])
  quantity      Int

  @@index([fulfillmentId])
}

// Phase 7b.6 — Refund audit trail.
//
// One row per refund issued against an Order. Captures the Stripe refund id
// for cross-reference, the initiator (admin user or null for system/customer-
// cancel paths), the amount in cents, and a free-text reason + notes.
//
// Multiple refunds can exist per Order (partial refunds accumulate). Sum of
// amountCents must not exceed Order.totalAmount * 100. Enforcement is in the
// refundOrder server action, not at the DB level.
model Refund {
  id                String   @id @default(uuid())
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  initiatedByUserId String?  // null = system (customer-cancel or webhook)
  initiatedBy       User?    @relation(fields: [initiatedByUserId], references: [id])
  amountCents       Int      // refund amount in cents
  reason            String   // 'customer_cancellation' | 'admin_full' | 'admin_partial' | 'admin_other'
  notes             String?  // optional free-text admin note
  stripeRefundId    String?  @unique
  restoredStock     Boolean  @default(false) // did we run restoreStock?
  reversedTax       Boolean  @default(false) // did we issue a tax reversal?
  createdAt         DateTime @default(now())

  @@index([orderId])
  @@index([initiatedByUserId])
}

