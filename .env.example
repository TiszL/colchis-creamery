# Database
DATABASE_URL="file:./prisma/dev.db"

# Authentication
JWT_SECRET="your-secret-key-change-in-production"

# Stripe (PLACEHOLDER - set when company is established)
STRIPE_SECRET_KEY="sk_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"
STRIPE_PUBLISHABLE_KEY="pk_placeholder"

# Adobe Sign (PLACEHOLDER - set when account is created)
ADOBE_ACCESS_TOKEN="placeholder"
ADOBE_B2B_TEMPLATE_ID="placeholder"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

#resend api

RESEND_API_KEY=
EMAIL_FROM=noreply@updates.colchiscreamery.com

# Vercel Blob Storage (for image/video uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_token_here"
